<ui:FluentWindow x:Class="AssetCuaStudio.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
                 xmlns:loc="clr-namespace:AssetCuaStudio"
                 Title="Asset CUA Studio"
                 Icon="pack://application:,,,/AssetCuaStudio.ico"
                 Width="1180" Height="780" MinWidth="1000" MinHeight="640"
                 WindowBackdropType="Mica" ExtendsContentIntoTitleBar="True"
                 WindowStartupLocation="CenterScreen">
  <ui:FluentWindow.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />
  </ui:FluentWindow.Resources>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <ui:TitleBar Grid.Row="0" Title="Asset CUA Studio" />

    <!-- header -->
    <Grid Grid.Row="1" Margin="24,10,24,8">
      <StackPanel>
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="ASSET CUA STUDIO" FontSize="24" FontWeight="Bold"
                     Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
          <TextBlock Text="by Shadow Venom" FontSize="12" VerticalAlignment="Bottom" Margin="10,0,0,4"
                     Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </StackPanel>
        <TextBlock Text="{Binding [subtitle], Source={x:Static loc:L.I}}" FontSize="13" Margin="0,2,0,0"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
      </StackPanel>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
        <ui:Button x:Name="OpenProjectBtn" Appearance="Secondary" Padding="9,5" Margin="0,0,6,0" Click="OnOpenProject"
                   ToolTip="{Binding [open_project], Source={x:Static loc:L.I}}">
          <ui:SymbolIcon Symbol="FolderOpen24" FontSize="16" />
        </ui:Button>
        <ui:Button x:Name="SaveProjectBtn" Appearance="Secondary" Padding="9,5" Margin="0,0,6,0" Click="OnSaveProject"
                   ToolTip="{Binding [save_project], Source={x:Static loc:L.I}}">
          <ui:SymbolIcon Symbol="Save24" FontSize="16" />
        </ui:Button>
        <ui:Button x:Name="SettingsBtn" Appearance="Secondary" Padding="9,5" Margin="0,0,8,0" Click="OnToggleSettings">
          <ui:SymbolIcon Symbol="Settings24" FontSize="16" />
        </ui:Button>
        <ComboBox x:Name="LangBox" Width="130" SelectionChanged="OnLangChanged" />
        <Popup x:Name="SettingsPopup" PlacementTarget="{Binding ElementName=SettingsBtn}" Placement="Bottom"
               StaysOpen="False" AllowsTransparency="True">
          <Border Background="{DynamicResource ApplicationBackgroundBrush}" BorderBrush="#555" BorderThickness="1"
                  CornerRadius="8" Padding="16" Width="330" Margin="0,4,0,0">
            <StackPanel>
              <TextBlock Text="{Binding [settings], Source={x:Static loc:L.I}}" FontWeight="Bold" Margin="0,0,0,10"
                         Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
              <TextBlock Text="{Binding [pref_prefix], Source={x:Static loc:L.I}}" FontSize="12"
                         Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
              <ui:TextBox x:Name="PrefixBox" TextChanged="OnSettingsChanged" Margin="0,2,0,10" />
              <TextBlock Text="{Binding [pref_output], Source={x:Static loc:L.I}}" FontSize="12"
                         Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
              <Grid Margin="0,2,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:TextBox x:Name="OutDefaultBox" Grid.Column="0" TextChanged="OnSettingsChanged" />
                <ui:Button Grid.Column="1" Margin="8,0,0,0" Content="{Binding [browse], Source={x:Static loc:L.I}}" Click="OnPickDefaultOut" />
              </Grid>
              <TextBlock Text="{Binding [pref_nav], Source={x:Static loc:L.I}}" FontSize="12" Margin="0,12,0,0"
                         Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
              <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" /><ColumnDefinition Width="6" />
                  <ColumnDefinition Width="*" /><ColumnDefinition Width="6" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding [nav_btn_left], Source={x:Static loc:L.I}}" FontSize="11" Margin="2,0,0,1"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding [nav_btn_mid], Source={x:Static loc:L.I}}" FontSize="11" Margin="2,0,0,1"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <TextBlock Grid.Row="0" Grid.Column="4" Text="{Binding [nav_btn_right], Source={x:Static loc:L.I}}" FontSize="11" Margin="2,0,0,1"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <ComboBox x:Name="NavLeftBox" Grid.Row="1" Grid.Column="0" SelectionChanged="OnNavChanged" />
                <ComboBox x:Name="NavMiddleBox" Grid.Row="1" Grid.Column="2" SelectionChanged="OnNavChanged" />
                <ComboBox x:Name="NavRightBox" Grid.Row="1" Grid.Column="4" SelectionChanged="OnNavChanged" />
              </Grid>
              <TextBlock Text="{Binding [nav_hint], Source={x:Static loc:L.I}}" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"
                         Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
              <TextBlock Text="{Binding [pref_persist], Source={x:Static loc:L.I}}" FontSize="11" Margin="0,10,0,0" TextWrapping="Wrap"
                         Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
          </Border>
        </Popup>
      </StackPanel>
    </Grid>

    <!-- 3-column convert panel -->
    <Grid Grid.Row="2" Margin="24,0,24,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="290" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="376" />
      </Grid.ColumnDefinitions>

      <!-- LEFT: glb queue (whole panel is the drop target) -->
      <Border Grid.Column="0" CornerRadius="10" AllowDrop="True" Drop="OnQueueDrop" DragOver="OnDragOver"
              Background="{DynamicResource ControlFillColorDefaultBrush}"
              BorderBrush="{DynamicResource AccentControlElevationBorderBrush}" BorderThickness="1.5">
        <Grid Margin="8">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <DockPanel Grid.Row="0" LastChildFill="False" Margin="2,2,2,6">
            <ui:Button DockPanel.Dock="Left" Padding="11,6" Content="{Binding [add_files], Source={x:Static loc:L.I}}" Click="OnAddFiles" Margin="0,0,6,0" />
            <ui:Button DockPanel.Dock="Left" Padding="11,6" Content="{Binding [add_folder], Source={x:Static loc:L.I}}" Click="OnAddFolder" />
            <ui:Button DockPanel.Dock="Left" Margin="12,0,0,0" Appearance="Secondary" Padding="9,6" Click="OnClear"
                       ToolTip="{Binding [clear], Source={x:Static loc:L.I}}">
              <ui:SymbolIcon Symbol="Delete24" FontSize="15" />
            </ui:Button>
          </DockPanel>
          <TextBlock x:Name="QueueCount" Grid.Row="1" Margin="2,0,2,8" FontSize="12"
                     Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
          <Grid Grid.Row="2">
            <ListBox x:Name="GlbList" Background="Transparent" BorderThickness="0" SelectionMode="Extended"
                     HorizontalContentAlignment="Stretch" SelectionChanged="OnGlbSelected"
                     ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto" />
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                      <ColumnDefinition Width="Auto" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <CheckBox Grid.Column="0" IsChecked="{Binding IsChecked, Mode=TwoWay}" Click="OnPackChanged"
                              IsEnabled="{Binding CanPack}" ToolTipService.ShowOnDisabled="True"
                              ToolTip="{Binding [pack_hint], Source={x:Static loc:L.I}}"
                              VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBlock Grid.Column="1" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Text="{Binding Display}" />
                    <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="13" Margin="6,0,2,0" Foreground="#FFCC66"
                               ToolTip="unsaved changes" Text="{Binding DirtyMark}" />
                    <TextBlock Grid.Column="3" VerticalAlignment="Center" FontSize="11" Margin="4,0,4,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="{Binding Verdict}" />
                    <ui:Button Grid.Column="4" Content="✕" Padding="7,1" FontSize="11" Appearance="Secondary"
                               Tag="{Binding Full}" Click="OnRemove"
                               Visibility="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}, Converter={StaticResource BoolToVis}}" />
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
            <StackPanel x:Name="EmptyHint" VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False">
              <ui:SymbolIcon Symbol="Cube24" FontSize="32" HorizontalAlignment="Center"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
              <TextBlock Text="{Binding [drop_glb], Source={x:Static loc:L.I}}" Margin="0,8,0,2" TextWrapping="Wrap"
                         FontSize="13" TextAlignment="Center" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
              <TextBlock Text="{Binding [drop_hint], Source={x:Static loc:L.I}}" FontSize="11"
                         HorizontalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
          </Grid>
        </Grid>
      </Border>

      <!-- CENTER: 3D preview -->
      <Border Grid.Column="1" Margin="12,0,12,0" CornerRadius="10" ClipToBounds="True"
              BorderBrush="{DynamicResource AccentControlElevationBorderBrush}" BorderThickness="1.5">
        <wv2:WebView2 x:Name="Web" />
      </Border>

      <!-- RIGHT: params (scroll) + pinned convert footer -->
      <Grid Grid.Column="2">
        <Grid.RowDefinitions>
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
        <StackPanel>
          <!-- quick / advanced toggle -->
          <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <ui:Button x:Name="BtnQuick" Appearance="Primary" MinWidth="100" Margin="0,0,8,0"
                       Content="{Binding [mode_quick], Source={x:Static loc:L.I}}" Click="OnQuick" />
            <ui:Button x:Name="BtnAdvanced" Appearance="Secondary" MinWidth="100"
                       Content="{Binding [mode_advanced], Source={x:Static loc:L.I}}" Click="OnAdvanced" />
          </StackPanel>

          <ui:Card Padding="16">
            <StackPanel>
              <TextBlock Text="{Binding [package_name], Source={x:Static loc:L.I}}" Margin="0,0,0,4"
                         Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
              <ui:TextBox x:Name="NameBox" PlaceholderText="MY_MyModel" TextChanged="OnNameChanged" />

              <TextBlock Text="{Binding [save_to], Source={x:Static loc:L.I}}" Margin="0,12,0,4"
                         Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:TextBox x:Name="OutBox" Grid.Column="0" IsReadOnly="True" />
                <ui:Button Grid.Column="1" Margin="8,0,0,0" Content="{Binding [browse], Source={x:Static loc:L.I}}" Click="OnPickOut" />
              </Grid>

              <!-- target height is OPT-IN: default off = load at the model's real size; tick to normalize -->
              <CheckBox x:Name="NormalizeCheck" Margin="0,14,0,0" Click="OnNormalizeChanged">
                <TextBlock Text="{Binding [normalize_height], Source={x:Static loc:L.I}}" />
              </CheckBox>
              <ui:NumberBox x:Name="HeightBox" Value="1.8" Minimum="0.02" Maximum="50" SmallChange="0.05"
                            IsEnabled="False" Margin="0,4,0,0" />

              <Grid Margin="0,14,0,2">
                <TextBlock Text="{Binding [yaw], Source={x:Static loc:L.I}}" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                <TextBlock x:Name="YawVal" Text="0°" HorizontalAlignment="Right" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
              </Grid>
              <Slider x:Name="YawSlider" Minimum="0" Maximum="360" Value="0" TickFrequency="15"
                      IsSnapToTickEnabled="False" ValueChanged="OnYawChanged" />

              <TextBlock Text="{Binding [position], Source={x:Static loc:L.I}}" Margin="0,14,0,4"
                         Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,4,0">
                  <TextBlock Text="X" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                  <ui:NumberBox x:Name="PosXBox" Value="0" SmallChange="0.05" MaxDecimalPlaces="3"
                                SpinButtonPlacementMode="Hidden" ClearButtonEnabled="False" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="2,0,2,0">
                  <TextBlock Text="Y" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                  <ui:NumberBox x:Name="PosYBox" Value="0" SmallChange="0.05" MaxDecimalPlaces="3"
                                SpinButtonPlacementMode="Hidden" ClearButtonEnabled="False" />
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="4,0,0,0">
                  <TextBlock Text="Z" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                  <ui:NumberBox x:Name="PosZBox" Value="0" SmallChange="0.05" MaxDecimalPlaces="3"
                                SpinButtonPlacementMode="Hidden" ClearButtonEnabled="False" />
                </StackPanel>
              </Grid>

              <Grid x:Name="PingPongRow" Margin="0,12,0,0" Visibility="Collapsed">
                <StackPanel Margin="0,0,46,0">
                  <TextBlock Text="{Binding [pingpong], Source={x:Static loc:L.I}}"
                             Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                  <TextBlock Text="{Binding [pingpong_hint], Source={x:Static loc:L.I}}" FontSize="11" TextWrapping="Wrap"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <ui:ToggleSwitch x:Name="PingPongSwitch" HorizontalAlignment="Right" VerticalAlignment="Top"
                                 Checked="OnPingPongChanged" Unchecked="OnPingPongChanged" />
              </Grid>

              <Grid x:Name="VColorRow" Margin="0,12,0,0" Visibility="Collapsed">
                <StackPanel Margin="0,0,46,0">
                  <TextBlock Text="{Binding [vcolor], Source={x:Static loc:L.I}}"
                             Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                  <TextBlock Text="{Binding [vcolor_hint], Source={x:Static loc:L.I}}" FontSize="11" TextWrapping="Wrap"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <ui:ToggleSwitch x:Name="VColorSwitch" HorizontalAlignment="Right" VerticalAlignment="Top"
                                 Checked="OnVertexColorChanged" Unchecked="OnVertexColorChanged" />
              </Grid>

              <StackPanel x:Name="AnimRow" Margin="0,12,0,0" Visibility="Collapsed">
                <TextBlock Text="{Binding [anim_clip], Source={x:Static loc:L.I}}" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                <ComboBox x:Name="AnimCombo" HorizontalAlignment="Stretch" SelectionChanged="OnAnimChanged" />
              </StackPanel>

              <Grid Margin="0,10,0,0">
                <TextBlock Text="{Binding [show_ref], Source={x:Static loc:L.I}}" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                <ui:ToggleSwitch x:Name="RefSwitch" IsChecked="True" HorizontalAlignment="Right" Checked="OnParamChanged" Unchecked="OnParamChanged" />
              </Grid>
            </StackPanel>
          </ui:Card>

          <!-- advanced editing (hidden in quick mode) -->
          <ui:Card x:Name="AdvancedCard" Padding="16" Margin="0,12,0,0" Visibility="Collapsed">
            <StackPanel>
              <TextBlock Text="{Binding [adv_title], Source={x:Static loc:L.I}}" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
              <TextBlock Text="{Binding [adv_hint], Source={x:Static loc:L.I}}" FontSize="11" Margin="0,2,0,12"
                         TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

              <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <ui:SymbolIcon Symbol="Sparkle24" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                <TextBlock Text="{Binding [sec_opacity], Source={x:Static loc:L.I}}" FontWeight="SemiBold" FontSize="13"
                           VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
              </StackPanel>

              <Grid Margin="0,0,0,10">
                <StackPanel Margin="0,0,46,0">
                  <TextBlock Text="{Binding [force_opaque], Source={x:Static loc:L.I}}"
                             Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                  <TextBlock Text="{Binding [force_opaque_hint], Source={x:Static loc:L.I}}" FontSize="11" TextWrapping="Wrap"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <ui:ToggleSwitch x:Name="ForceOpaqueSwitch" HorizontalAlignment="Right" VerticalAlignment="Top"
                                 Checked="OnForceOpaqueChanged" Unchecked="OnForceOpaqueChanged" />
              </Grid>

              <Separator Margin="0,16,0,10" />
              <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <ui:SymbolIcon Symbol="Cube24" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                <TextBlock Text="{Binding [collider], Source={x:Static loc:L.I}}" FontWeight="SemiBold" FontSize="13"
                           VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
              </StackPanel>
              <ComboBox x:Name="ColliderCombo" SelectedValuePath="Content" SelectionChanged="OnColliderChanged" HorizontalAlignment="Stretch">
                <ComboBoxItem Content="none" /><ComboBoxItem Content="box" /><ComboBoxItem Content="convex" /><ComboBoxItem Content="mesh" />
              </ComboBox>
              <TextBlock Text="{Binding [collider_hint], Source={x:Static loc:L.I}}" FontSize="11" Margin="0,3,0,0" TextWrapping="Wrap"
                         Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
              <Border x:Name="ColliderWarn" Margin="0,6,0,0" Padding="9,6" CornerRadius="6" Visibility="Collapsed"
                      Background="#33FF6B6B" BorderBrush="#FF6B6B" BorderThickness="1">
                <TextBlock x:Name="ColliderWarnText" FontSize="11" TextWrapping="Wrap" Foreground="#FFB3B3" />
              </Border>

              <Separator Margin="0,16,0,10" />
              <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <ui:SymbolIcon Symbol="Image24" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                <TextBlock Text="{Binding [tex_quality], Source={x:Static loc:L.I}}" FontWeight="SemiBold" FontSize="13"
                           VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
              </StackPanel>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding [tex_target], Source={x:Static loc:L.I}}" VerticalAlignment="Center" FontSize="11"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <ComboBox Grid.Column="1" x:Name="TexTargetCombo" SelectedValuePath="Content" SelectionChanged="OnTexTargetChanged" Margin="8,0,0,0">
                  <ComboBoxItem Content="full" /><ComboBoxItem Content="1024" /><ComboBoxItem Content="512" /><ComboBoxItem Content="256" />
                </ComboBox>
              </Grid>
              <CheckBox x:Name="TexNormalCheck" Click="OnTexSlimChanged" Margin="0,6,0,0">
                <TextBlock Text="{Binding [tex_slim_normal], Source={x:Static loc:L.I}}" /></CheckBox>
              <CheckBox x:Name="TexSpecCheck" Click="OnTexSlimChanged" Margin="0,2,0,0">
                <TextBlock Text="{Binding [tex_slim_spec], Source={x:Static loc:L.I}}" /></CheckBox>
              <CheckBox x:Name="TexAlbedoCheck" Click="OnTexSlimChanged" Margin="0,2,0,0">
                <TextBlock Text="{Binding [tex_slim_albedo], Source={x:Static loc:L.I}}" /></CheckBox>
              <TextBlock Text="{Binding [tex_albedo_hint], Source={x:Static loc:L.I}}" FontSize="11" Margin="0,2,0,0" TextWrapping="Wrap"
                         Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

              <Separator Margin="0,16,0,10" />
              <Grid Margin="0,0,0,4">
                <StackPanel Orientation="Horizontal">
                  <ui:SymbolIcon Symbol="Color24" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"
                                 Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                  <TextBlock Text="{Binding [adv_materials], Source={x:Static loc:L.I}}" FontWeight="SemiBold" FontSize="13"
                             VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                </StackPanel>
                <ui:Button HorizontalAlignment="Right" Appearance="Secondary" Padding="8,2" FontSize="11" Click="OnResetMaterials"
                           Content="{Binding [mat_reset], Source={x:Static loc:L.I}}" />
              </Grid>
              <ItemsControl x:Name="MatList">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Expander Margin="0,0,0,4" Padding="0,2,0,4">
                      <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                          <Border Width="12" Height="12" CornerRadius="6" VerticalAlignment="Center" Margin="0,0,8,0"
                                  Background="{Binding TypeColor}" />
                          <TextBlock Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="170" />
                          <TextBlock Text="{Binding TypeLabel}" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="10"
                                     Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                      </Expander.Header>
                      <StackPanel Margin="20,4,0,0">
                        <TextBlock Text="{Binding [mat_mode], Source={x:Static loc:L.I}}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <ComboBox SelectedValue="{Binding Mode, Mode=TwoWay}" SelectedValuePath="Content" HorizontalAlignment="Stretch" Margin="0,2,0,6">
                          <ComboBoxItem Content="opaque" /><ComboBoxItem Content="cutout" /><ComboBoxItem Content="fade" />
                        </ComboBox>

                        <Grid Margin="0,0,0,6">
                          <TextBlock Text="{Binding [mat_color], Source={x:Static loc:L.I}}" VerticalAlignment="Center" FontSize="11"
                                     Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                          <Button HorizontalAlignment="Right" Width="46" Height="22" Click="OnPickBaseColor" Tag="{Binding}"
                                  Background="{Binding ColorBrush}" BorderBrush="#555" BorderThickness="1" />
                        </Grid>

                        <StackPanel Visibility="{Binding HasMetal, Converter={StaticResource BoolToVis}}">
                          <Grid>
                            <TextBlock Text="{Binding [mat_metallic], Source={x:Static loc:L.I}}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            <TextBlock Text="{Binding Metallic, StringFormat=N2}" HorizontalAlignment="Right" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                          </Grid>
                          <Slider Minimum="0" Maximum="1" Value="{Binding Metallic, Mode=TwoWay}" Margin="0,0,0,4" />
                        </StackPanel>

                        <Grid>
                          <TextBlock Text="{Binding [mat_smoothness], Source={x:Static loc:L.I}}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                          <TextBlock Text="{Binding Smoothness, StringFormat=N2}" HorizontalAlignment="Right" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </Grid>
                        <Slider Minimum="0" Maximum="1" Value="{Binding Smoothness, Mode=TwoWay}" Margin="0,0,0,4" />

                        <StackPanel Visibility="{Binding IsCutout, Converter={StaticResource BoolToVis}}">
                          <Grid>
                            <TextBlock Text="{Binding [mat_cutoff], Source={x:Static loc:L.I}}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            <TextBlock Text="{Binding Cutoff, StringFormat=N2}" HorizontalAlignment="Right" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                          </Grid>
                          <Slider Minimum="0" Maximum="1" Value="{Binding Cutoff, Mode=TwoWay}" Margin="0,0,0,4" />
                        </StackPanel>

                        <!-- emission: only for materials that are emissive at source; on/off toggle to cancel it -->
                        <StackPanel Visibility="{Binding HasEmission, Converter={StaticResource BoolToVis}}" Margin="0,2,0,0">
                          <Grid>
                            <TextBlock Text="{Binding [mat_emission], Source={x:Static loc:L.I}}" VerticalAlignment="Center" FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            <ui:ToggleSwitch IsChecked="{Binding EmissionEnabled, Mode=TwoWay}" HorizontalAlignment="Right" />
                          </Grid>
                          <StackPanel Visibility="{Binding EmissionEnabled, Converter={StaticResource BoolToVis}}" Margin="0,4,0,0">
                            <Grid>
                              <TextBlock Text="{Binding [mat_color], Source={x:Static loc:L.I}}" VerticalAlignment="Center" FontSize="11"
                                         Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                              <Button HorizontalAlignment="Right" Width="46" Height="22" Click="OnPickEmissionColor" Tag="{Binding}"
                                      Background="{Binding EmissionBrush}" BorderBrush="#555" BorderThickness="1" />
                            </Grid>
                            <Grid Margin="0,4,0,0">
                              <TextBlock Text="{Binding [mat_intensity], Source={x:Static loc:L.I}}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                              <TextBlock Text="{Binding EmissionIntensity, StringFormat=N2}" HorizontalAlignment="Right" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </Grid>
                            <Slider Minimum="0" Maximum="4" Value="{Binding EmissionIntensity, Mode=TwoWay}" Margin="0,2,0,4" />
                          </StackPanel>
                        </StackPanel>

                        <Grid>
                          <TextBlock Text="{Binding [mat_normal], Source={x:Static loc:L.I}}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                          <TextBlock Text="{Binding NormalScale, StringFormat=N2}" HorizontalAlignment="Right" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </Grid>
                        <Slider Minimum="0" Maximum="3" Value="{Binding NormalScale, Mode=TwoWay}" Margin="0,0,0,4" />

                        <Grid Margin="0,2,0,0">
                          <TextBlock Text="{Binding [mat_twosided], Source={x:Static loc:L.I}}" VerticalAlignment="Center" FontSize="11"
                                     Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                          <ui:ToggleSwitch IsChecked="{Binding TwoSided, Mode=TwoWay}" HorizontalAlignment="Right" />
                        </Grid>
                      </StackPanel>
                    </Expander>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <Separator Margin="0,16,0,10" />
              <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <ui:SymbolIcon Symbol="PlayCircle24" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                <TextBlock Text="{Binding [adv_anim], Source={x:Static loc:L.I}}" FontWeight="SemiBold" FontSize="13"
                           VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
              </StackPanel>
              <ItemsControl x:Name="AnimList" />
            </StackPanel>
          </ui:Card>

          <CheckBox x:Name="OpenFolderCheck" Margin="0,12,0,0" Checked="OnOpenFolderChanged" Unchecked="OnOpenFolderChanged">
            <TextBlock Text="{Binding [open_when_done], Source={x:Static loc:L.I}}" />
          </CheckBox>

          <Border x:Name="RiskHint" Margin="0,12,0,0" Padding="10,7" CornerRadius="6" Visibility="Collapsed"
                  Background="#33FFCC66" BorderBrush="#FFCC66" BorderThickness="1">
            <TextBlock Text="{Binding [risk_hint], Source={x:Static loc:L.I}}" FontSize="12" TextWrapping="Wrap"
                       Foreground="#FFD98A" />
          </Border>
          <Border x:Name="VColorHint" Margin="0,12,0,0" Padding="10,7" CornerRadius="6" Visibility="Collapsed"
                  Background="#3366CCFF" BorderBrush="#66CCFF" BorderThickness="1">
            <TextBlock Text="{Binding [vcolor_auto], Source={x:Static loc:L.I}}" FontSize="12" TextWrapping="Wrap"
                       Foreground="#9FD8FF" />
          </Border>
        </StackPanel>
        </ScrollViewer>

        <!-- pinned convert footer — always visible, no matter how far the params scroll -->
        <Border Grid.Row="1" Margin="0,8,0,0" Padding="0,10,0,0" BorderThickness="0,1,0,0" BorderBrush="#22FFFFFF">
          <StackPanel>
            <ui:ToggleSwitch x:Name="PackSwitch" Visibility="Collapsed" Margin="0,0,0,6"
                             Content="{Binding [pack_toggle], Source={x:Static loc:L.I}}"
                             Checked="OnPackModeChanged" Unchecked="OnPackModeChanged" />
            <TextBlock x:Name="PackInfo" FontSize="12" TextWrapping="Wrap"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            <ui:Button x:Name="ConvertBtn" Margin="0,6,0,0" MinHeight="44" HorizontalAlignment="Stretch"
                       Appearance="Primary" FontSize="15"
                       Content="{Binding [convert_btn], Source={x:Static loc:L.I}}" Click="OnConvert" />
            <ProgressBar x:Name="Progress" Height="6" Margin="0,10,0,0" Minimum="0" Maximum="100" Visibility="Collapsed" />
            <ui:InfoBar x:Name="Result" Margin="0,10,0,0" IsOpen="False" />
          </StackPanel>
        </Border>
      </Grid>
    </Grid>

    <Border Grid.Row="3" Background="{DynamicResource ControlFillColorDefaultBrush}" Padding="24,8">
      <TextBlock x:Name="StatusText" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
    </Border>
  </Grid>
</ui:FluentWindow>
